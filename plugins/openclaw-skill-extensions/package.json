{
  "name": "@heretek-ai/openclaw-skill-extensions",
  "version": "1.0.0",
  "description": "Custom skill extensions for OpenClaw with composition and versioning",
  "main": "src/index.js",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "start": "node src/index.js",
    "lint": "eslint src/"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "skills",
    "extensions",
    "composition",
    "versioning",
    "workflow"
  ],
  "author": "Heretek-AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/heretek/heretek-openclaw-plugins.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ioredis": "^5.3.2",
    "lru-cache": "^10.1.0",
    "async": "^3.2.5",
    "semver": "^7.5.4"
  },
  "peerDependencies": {
    "openclaw": ">=1.0.0"
  },
  "openclaw": {
    "extensions": [
      "./src/index.js"
    ],
    "plugin": {
      "name": "skill-extensions",
      "version": "1.0.0",
      "description": "Custom skill extensions with composition and versioning",
      "capabilities": [
        "workflow-skills",
        "skill-composition",
        "skill-versioning",
        "skill-discovery",
        "skill-registry"
      ]
    }
  }
}
