# ==============================================================================
# ClawBridge Dashboard Configuration for Heretek OpenClaw
# ==============================================================================
# Version: 1.0.0
# Last Updated: 2026-04-01
#
# Copy this file to .env and update with your values
# Usage: cp .env.example .env
# ==============================================================================

# ==============================================================================
# DASHBOARD SERVER CONFIGURATION
# ==============================================================================
# Dashboard web interface binding and port settings
# ==============================================================================

# Dashboard server port
DASHBOARD_PORT=18790

# Dashboard server host binding
# Use 0.0.0.0 for all interfaces, 127.0.0.1 for localhost only
DASHBOARD_HOST=0.0.0.0

# Health API port for monitoring endpoints
HEALTH_API_PORT=18080

# Health API host binding
HEALTH_API_HOST=0.0.0.0

# Health check interval in milliseconds
HEALTH_API_INTERVAL=5000

# ==============================================================================
# LITEELM GATEWAY CONFIGURATION
# ==============================================================================
# Connection settings for the LiteLLM gateway
# ==============================================================================

# LiteLLM gateway URL (Docker network)
# For local access without Docker, use http://localhost:4000
LITELLM_URL=http://litellm:4000

# LiteLLM Master Key for authentication
# Must match LITELLM_MASTER_KEY in heretek-openclaw-core/.env
# Generate with: openssl rand -hex 32
LITELLM_MASTER_KEY=<your-litellm-master-key>

# ==============================================================================
# SERVICE ENDPOINTS (Docker Network URLs)
# ==============================================================================
# Internal service connections within the Docker network
# For external access, replace service names with localhost or IP addresses
# ==============================================================================

# OpenClaw Gateway URL
GATEWAY_URL=http://gateway:18789

# Langfuse Observability Platform
LANGFUSE_URL=http://langfuse:3000

# PostgreSQL Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=<your-postgres-user>
POSTGRES_PASSWORD=<your-postgres-password>

# Redis Cache
REDIS_HOST=redis
REDIS_PORT=6379

# Ollama Local LLM Server
OLLAMA_URL=http://ollama:11434

# Neo4j Graph Database
NEO4J_URL=bolt://neo4j:7687

# ==============================================================================
# PROMETHEUS CONFIGURATION
# ==============================================================================
# Prometheus metrics collection and monitoring
# ==============================================================================

# Prometheus server URL
PROMETHEUS_URL=http://prometheus:9090

# Prometheus server port
PROMETHEUS_PORT=9090

# ==============================================================================
# GRAFANA CONFIGURATION
# ==============================================================================
# Grafana visualization and dashboard platform
# ==============================================================================

# Grafana server port
GRAFANA_PORT=3001

# Grafana admin username
GRAFANA_ADMIN_USER=<your-grafana-admin-user>

# Grafana admin password
# CHANGE THIS IN PRODUCTION!
GRAFANA_ADMIN_PASSWORD=<your-grafana-admin-password>

# ==============================================================================
# MONITORING STACK PORTS
# ==============================================================================
# Exporter ports for the monitoring stack
# These services expose metrics for Prometheus to scrape
# ==============================================================================

# Node Exporter (system metrics)
NODE_EXPORTER_PORT=9100

# cAdvisor (container metrics)
CADVISOR_PORT=8080

# Redis Exporter (Redis metrics)
REDIS_EXPORTER_PORT=9121

# Postgres Exporter (PostgreSQL metrics)
POSTGRES_EXPORTER_PORT=9187

# Blackbox Exporter (endpoint probing)
BLACKBOX_EXPORTER_PORT=9115

# ==============================================================================
# SESSION CONFIGURATION
# ==============================================================================

# Session timeout in seconds
SESSION_TIMEOUT=3600

# ==============================================================================
# LOGGING
# ==============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log file path
LOG_FILE=/var/log/clawbridge/clawbridge.log

# ==============================================================================
# CLOUDFLARE TUNNEL CONFIGURATION
# ==============================================================================
# Optional Cloudflare Tunnel for secure external access
# ==============================================================================

# Enable Cloudflare Tunnel
CLOUDFLARE_TUNNEL_ENABLED=true

# Cloudflare Tunnel domain (assigned by Cloudflare)
CLOUDFLARE_TUNNEL_DOMAIN=

# Cloudflare Tunnel name
CLOUDFLARE_TUNNEL_NAME=clawbridge-openclaw

# ==============================================================================
# END OF CONFIGURATION
# ==============================================================================
