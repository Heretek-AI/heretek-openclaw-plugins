{
  "id": "basic-plugin",
  "displayName": "Basic Plugin Template",
  "version": "1.0.0",
  "description": "A basic OpenClaw plugin template for getting started",
  "kind": "utility",
  "keywords": ["template", "basic", "starter"],
  "author": {
    "name": "Your Name",
    "email": "your@email.com"
  },
  "repository": "https://github.com/your-org/openclaw-basic-plugin",
  "license": "MIT",
  "main": "src/index.js",
  "files": [
    "package.json",
    "README.md",
    "SKILL.md",
    "src/index.js",
    "config/default.json",
    ".env.example"
  ],
  "variables": {
    "pluginName": {
      "type": "string",
      "description": "Plugin name (kebab-case)",
      "required": true
    },
    "pluginDisplayName": {
      "type": "string",
      "description": "Human-readable plugin name",
      "required": true
    },
    "pluginDescription": {
      "type": "string",
      "description": "Plugin description",
      "required": true
    },
    "authorName": {
      "type": "string",
      "description": "Author name",
      "required": true
    },
    "authorEmail": {
      "type": "string",
      "description": "Author email",
      "required": false
    }
  }
}
