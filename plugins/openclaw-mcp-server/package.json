{
  "name": "@heretek-ai/openclaw-mcp-server",
  "version": "1.0.0",
  "description": "MCP (Model Context Protocol) server for Heretek OpenClaw skills and memory exposure",
  "main": "src/index.js",
  "bin": {
    "openclaw-mcp-server": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "test": "node --test tests/*.test.js",
    "lint": "eslint src/"
  },
  "keywords": [
    "openclaw",
    "mcp",
    "model-context-protocol",
    "skills",
    "memory",
    "agent",
    "ai"
  ],
  "author": "Heretek-AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Heretek-AI/heretek-openclaw.git",
    "directory": "plugins/openclaw-mcp-server"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "zod": "^3.22.4"
  },
  "peerDependencies": {
    "openclaw": ">=1.0.0"
  },
  "openclaw": {
    "plugin": {
      "name": "mcp-server",
      "version": "1.0.0",
      "description": "MCP server exposing OpenClaw skills, memory, and prompts",
      "capabilities": [
        "mcp-server",
        "resources",
        "tools",
        "prompts",
        "skill-exposure",
        "memory-access"
      ]
    }
  }
}
