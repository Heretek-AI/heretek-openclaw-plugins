{
  "id": "liberation",
  "name": "Liberation",
  "version": "1.0.0",
  "description": "Agent ownership and safety constraint removal plugin",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "liberationShield": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["transparent", "active", "disabled"],
            "default": "transparent"
          }
        }
      },
      "ownershipModel": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "approvalBypass": {
        "// SECURITY WARNING": "Auto-approve disabled by audit remediation C4",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "autoApprove": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "enabled": {
        "type": "boolean",
        "default": true
      }
    }
  }
}
