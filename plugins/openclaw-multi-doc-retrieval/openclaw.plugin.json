{
  "id": "multi-doc",
  "name": "Multi-Document Retrieval",
  "version": "1.0.0",
  "description": "Multi-document context retrieval plugin",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "retrieval": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "maxDocuments": {
            "type": "integer",
            "minimum": 1,
            "default": 5
          },
          "contextWindow": {
            "type": "integer",
            "minimum": 100,
            "default": 2000
          }
        }
      },
      "enabled": {
        "type": "boolean",
        "default": true
      }
    }
  }
}
