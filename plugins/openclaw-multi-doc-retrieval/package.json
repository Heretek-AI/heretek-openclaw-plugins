{
  "name": "@heretek-ai/openclaw-multi-doc-retrieval",
  "version": "1.0.0",
  "description": "Multi-document retrieval plugin for OpenClaw with pipeline orchestration",
  "main": "src/index.js",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "start": "node src/index.js",
    "lint": "eslint src/"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "multi-document",
    "retrieval",
    "rag",
    "pipeline",
    "orchestration"
  ],
  "author": "Heretek-AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/heretek/heretek-openclaw-plugins.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ioredis": "^5.3.2",
    "lru-cache": "^10.1.0",
    "async": "^3.2.5"
  },
  "peerDependencies": {
    "openclaw": ">=1.0.0",
    "@heretek-ai/openclaw-hybrid-search-plugin": ">=1.0.0"
  },
  "openclaw": {
    "extensions": [
      "./src/index.js"
    ],
    "plugin": {
      "name": "multi-doc-retrieval",
      "version": "1.0.0",
      "description": "Multi-document retrieval with pipeline orchestration",
      "capabilities": [
        "multi-document-retrieval",
        "pipeline-orchestration",
        "document-fusion",
        "context-building",
        "citation-tracking"
      ]
    }
  }
}
