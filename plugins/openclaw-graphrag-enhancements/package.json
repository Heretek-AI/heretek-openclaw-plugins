{
  "name": "@heretek-ai/openclaw-graphrag-enhancements",
  "version": "1.0.0",
  "description": "GraphRAG enhancements for OpenClaw with entity extraction, community detection, and multi-hop reasoning",
  "main": "src/index.js",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "start": "node src/index.js",
    "lint": "eslint src/"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "graphrag",
    "graph-rag",
    "entity-extraction",
    "community-detection",
    "knowledge-graph",
    "multi-hop-reasoning"
  ],
  "author": "Heretek-AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Heretek-AI/heretek-openclaw.git",
    "directory": "plugins/openclaw-graphrag-enhancements"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "natural": "^6.10.4",
    "lru-cache": "^10.1.0",
    "cosine-similarity": "^1.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=1.0.0",
    "@heretek-ai/openclaw-hybrid-search-plugin": ">=1.0.0"
  },
  "openclaw": {
    "plugin": {
      "name": "graphrag-enhancements",
      "version": "1.0.0",
      "description": "GraphRAG with entity extraction, community detection, and multi-hop reasoning",
      "capabilities": [
        "entity-extraction",
        "relationship-mapping",
        "community-detection",
        "graph-traversal",
        "multi-hop-reasoning",
        "graph-rag"
      ],
      "config": {
        "entityTypes": ["person", "organization", "location", "concept", "event"],
        "relationshipTypes": ["related_to", "part_of", "causes", "similar_to", "references", "located_in", "member_of"],
        "communityResolution": 0.5,
        "maxHops": 3,
        "minCommunitySize": 2
      }
    }
  }
}
